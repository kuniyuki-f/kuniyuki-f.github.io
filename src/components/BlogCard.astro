---
interface Props {
  title: string;
  slug: string;
  date: Date;
  category?: string;
  thumbnail?: string;
  excerpt?: string;
}

const { title, slug, date, category, thumbnail, excerpt } = Astro.props;

const formattedDate = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---

<article class="max-w-[21.25rem] text-center">
  <a href={`/blog/${slug}/`} class="card-hover relative block p-5 no-underline">
    <!-- 画像コンテナ（16:9比率） -->
    <div class="thumb-zoom relative w-[18.75rem] h-[10.546875rem] mx-auto overflow-hidden rounded-[5px] shadow-[0_3px_10px_rgba(0,0,0,0.2)]">
      <img
        src={thumbnail || '/images/blog-default.jpg'}
        alt={title}
        loading="lazy"
        class="block w-full h-full object-cover transition-transform duration-300"
      />
    </div>
    <!-- タイトル -->
    <h3 class="card-title">{title}</h3>
    <!-- メタ情報（日付・カテゴリ） -->
    <div class="relative flex justify-between items-center max-w-[18.75rem] mx-auto text-[0.8125rem] z-[1]">
      <time class="text-[#888]" datetime={date.toISOString()}>
        {formattedDate}
      </time>
      {category && (
        <span class="text-[0.75rem] text-base bg-green px-[0.8rem] py-[0.2rem] rounded">
          {category}
        </span>
      )}
    </div>
    <!-- 抜粋 -->
    {excerpt && (
      <p class="card-desc max-w-[18.75rem] mx-auto py-4">{excerpt}</p>
    )}
  </a>
</article>
