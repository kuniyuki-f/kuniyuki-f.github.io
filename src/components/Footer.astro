---
const navItems = [
  { label: 'Works', href: '/works/' },
  { label: 'Profile', href: '/profile/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Contact', href: '/contact/' },
  { label: 'Privacy Policy', href: '/privacy/' },
];

const currentYear = new Date().getFullYear();
---

<footer class="footer">

  <!-- フッターロゴ -->
  <div class="footer__title">
    <a href="/">
      <img src="/images/footer_logo.png" alt="WEB制作 Swing" />
    </a>
  </div>

  <!-- フッターナビゲーション -->
  <nav class="footer__global-nav">
    <ul id="menu-footer-nav">
      {navItems.map((item) => (
        <li>
          <a href={item.href}>{item.label}</a>
        </li>
      ))}
    </ul>
  </nav>

  <!-- コピーライト -->
  <p class="footer__copyright">
    &copy;2021{currentYear !== 2021 ? `-${currentYear}` : ''} Swing
  </p>

</footer>

<style>
  /* =========================================
     元テーマ _footer.scss に忠実な実装
  ========================================= */
  footer {
    position: relative;
    color: #f4f3ec;
    background-color: #59483b;
    background-blend-mode: darken;
    text-align: center;
  }

  /* フッターロゴ */
  .footer__title {
    padding-top: 3.4375rem; /* 55px */
    text-align: center;
  }

  .footer__title img {
    max-width: 10rem; /* 160px */
    height: auto;
  }

  .footer__title a:hover {
    opacity: 0.8;
  }

  /* フッターナビゲーション */
  .footer__global-nav {
    margin-top: 0.625rem; /* 10px */
  }

  #menu-footer-nav {
    display: flex;
    flex-wrap: wrap;
    row-gap: 1.375rem; /* 22px */
    justify-content: space-evenly;
    max-width: 22.5rem; /* 360px */
    padding-top: 2.0625rem; /* 33px */
    margin: auto;
    list-style: none;
    padding-left: 0;
  }

  #menu-footer-nav a {
    color: #f4f3ec;
    text-decoration: none;
    font-size: 0.875rem; /* 14px */
    transition: opacity 0.2s;
    line-height: 1.5em;
    letter-spacing: 0.1em;
  }

  #menu-footer-nav a:hover {
    opacity: 0.7;
  }

  /* コピーライト */
  .footer__copyright {
    padding: 1.375rem 0; /* 22px */
    margin: auto;
    text-align: center;
    font-size: 0.875rem; /* 14px */
    color: #f4f3ec;
    line-height: 1.5em;
    letter-spacing: 0.1em;
  }
</style>
