---
const navItems = [
  { label: '制作実績', href: '/works/' },
  { label: '自己紹介', href: '/profile/' },
  { label: 'ブログ', href: '/blog/' },
  { label: 'お問い合わせ', href: '/contact/' },
  { label: 'プライバシーポリシー', href: '/privacy/' },
];

const currentYear = new Date().getFullYear();
---

<footer class="relative text-base bg-brown text-center">

  <!-- フッターロゴ -->
  <div class="pt-[3.4375rem] text-center">
    <a href="/" class="hover:opacity-80 transition-opacity duration-200">
      <img src="/images/footer_logo.png" alt="WEB工房 Swing" class="max-w-[10rem] h-auto" />
    </a>
  </div>

  <!-- フッターナビゲーション -->
  <nav class="mt-2.5">
    <ul class="flex flex-wrap justify-evenly max-w-[22.5rem] pt-[2.0625rem] mx-auto list-none p-0 gap-y-[1.375rem]">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="text-base no-underline text-[0.875rem] transition-opacity duration-200 hover:opacity-70"
          >{item.label}</a>
        </li>
      ))}
    </ul>
  </nav>

  <!-- コピーライト -->
  <p class="py-[1.375rem] mx-auto text-center text-[0.875rem] text-base">
    &copy;2021 {currentYear !== 2021 ? `-${currentYear} ` : ''}Swing
  </p>

</footer>
