---
// アイコンのみのナビ（元テーマのDB登録内容に準拠）
const navItems = [
  { icon: 'work_outline',  iconSet: 'material-icons',          label: 'Works',   href: '/works/' },
  { icon: 'face',          iconSet: 'material-icons',          label: 'Profile', href: '/profile/' },
  { icon: 'article',       iconSet: 'material-icons-outlined', label: 'Blog',    href: '/blog/' },
  { icon: 'mail',          iconSet: 'material-icons-outlined', label: 'Contact', href: '/contact/' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-[2] flex items-center justify-between h-[3.75rem] px-5 bg-base shadow-[0_3px_6px_#0000001a]">
  <!-- ロゴ（トップページはh1、それ以外はdiv） -->
  {currentPath === '/'
    ? <h1 class="m-0"><a href="/"><img src="/images/logo.png" alt="WEB工房 Swing" class="w-auto max-h-[3.75rem]" /></a></h1>
    : <div><a href="/"><img src="/images/logo.png" alt="WEB工房 Swing" class="w-auto max-h-[3.75rem]" /></a></div>
  }

  <!-- ナビゲーション（アイコンのみ、スマホは非表示） -->
  <nav class="sm:hidden">
    <ul class="flex h-[3.75rem] leading-[3.75rem] list-none m-0 p-0">
      {navItems.map((item) => (
        <li class:list={[{ 'text-green': currentPath.startsWith(item.href) }]}>
          <a
            href={item.href}
            title={item.label}
            class:list={[
              'flex items-center justify-center h-full px-4 ml-4 no-underline transition-colors duration-200',
              currentPath.startsWith(item.href) ? 'text-green' : 'text-brown hover:text-green'
            ]}
          >
            <i class={`${item.iconSet} text-[1.5rem] leading-[inherit]`}>{item.icon}</i>
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <!-- ハンバーガーボタン（スマホ用、PCは非表示） -->
  <button
    class="hidden sm:flex flex-col justify-center gap-[5px] w-[1.875rem] h-[1.875rem] bg-transparent border-none cursor-pointer p-0 flex-shrink-0"
    id="hamburger-btn"
    aria-label="メニューを開く"
  >
    <span class="block w-full h-[2px] bg-brown transition-transform duration-300 origin-center"></span>
    <span class="block w-full h-[2px] bg-brown transition-opacity duration-300"></span>
    <span class="block w-full h-[2px] bg-brown transition-transform duration-300 origin-center"></span>
  </button>

  <!-- スマホ用ドロワーメニュー（こちらは文字表示） -->
  <nav class="hidden fixed top-[3.75rem] left-0 w-full bg-base shadow-[0_4px_12px_rgba(0,0,0,0.15)] z-[99]" id="drawer">
    <ul class="list-none m-0 p-0">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="flex items-center gap-3 px-5 py-4 text-base text-brown no-underline border-b border-brown/15 transition-colors duration-200 hover:bg-brown/5 hover:text-green"
          >
            <i class={`${item.iconSet} text-[1.25rem]`}>{item.icon}</i>
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  /* ハンバーガーボタンのアニメーション（Tailwindだと状態管理が複雑なのでここで定義） */
  #hamburger-btn.is-open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  #hamburger-btn.is-open span:nth-child(2) {
    opacity: 0;
  }
  #hamburger-btn.is-open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
  /* スマホでロゴ幅を制限 */
  @media screen and (max-width: 767px) {
    header img {
      width: 11.25rem;
      max-height: none;
    }
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger-btn');
  const drawer = document.getElementById('drawer');

  hamburger?.addEventListener('click', () => {
    hamburger.classList.toggle('is-open');
    drawer?.classList.toggle('!block');
  });

  drawer?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      hamburger?.classList.remove('is-open');
      drawer.classList.remove('!block');
    });
  });
</script>
