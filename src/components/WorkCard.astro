---
interface Props {
  title: string;
  thumbnail: string;
  link: string;
  description?: string;
}

const { title, thumbnail, link, description } = Astro.props;
---

<article class="text-center">
  <a
    href={link}
    target="_blank"
    rel="noopener noreferrer"
    class="card-hover relative block p-5 no-underline"
  >
    <!-- 画像コンテナ（16:9比率） -->
    <div class="thumb-zoom relative w-[18.75rem] h-[10.546875rem] mx-auto overflow-hidden rounded-[5px] shadow-[0_3px_10px_rgba(0,0,0,0.2)]">
      <img
        src={thumbnail}
        alt={title}
        loading="lazy"
        class="w-full h-full object-cover transition-transform duration-300"
      />
    </div>
    <!-- タイトル -->
    <h3 class="card-title">{title}</h3>
    <!-- 説明文 -->
    {description && (
      <p class="card-desc max-w-[18.75rem] mx-auto pt-[0.6875rem]">{description}</p>
    )}
  </a>
</article>
