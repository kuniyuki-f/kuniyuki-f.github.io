---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = 'WEB工房 Swing - くにゆきのポートフォリオサイト', image } = Astro.props;
const pageTitle = `${title} - WEB工房 Swing`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://web-studio-swing.com');
// og:image は絶対URLが必須（相対パスのままだとSNSシェア時に画像が表示されない）
const ogImage = new URL(image || '/images/blog-default.jpg', canonicalURL).href;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- OGP -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="WEB工房 Swing" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- JSON-LD 構造化データ -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "WEB工房 Swing",
      "url": "https://web-studio-swing.com",
      "description": "フリーランスWEBデザイナー・エンジニア くにゆきのポートフォリオサイト",
      "author": {
        "@type": "Person",
        "name": "船坂 国之",
        "jobTitle": "フリーランスWEBエンジニア",
        "url": "https://web-studio-swing.com/profile/"
      }
    })} />

    <!-- Google Material Icons（Filled と Outlined 両方読み込む） -->
    <link
      href="https://fonts.googleapis.com/icon?family=Material+Icons|Material+Icons+Outlined"
      rel="stylesheet"
    />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-HDQJNK97HN"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-HDQJNK97HN');
    </script>
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
    <ScrollToTop />
  </body>
</html>
