---
import Layout from '../../layouts/Layout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const formattedDate = post.data.date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});

const formattedUpdatedDate = post.data.updatedDate
  ? post.data.updatedDate.toLocaleDateString('ja-JP', {
      year: 'numeric',
      month: '2-digit',
      day: '2-digit',
    })
  : null;

const pageUrl = Astro.url.href;
const pageTitle = post.data.title;
---

<Layout title={post.data.title} description={post.data.excerpt}>

  <main class="page-main">

    <!-- 記事ヘッダー（アイキャッチ背景） -->
    <div
      class="relative flex flex-col items-center justify-center w-full h-[20rem] text-[#ccc] text-center bg-[rgba(0,0,0,0.8)] bg-no-repeat bg-center bg-cover [background-blend-mode:darken]"
      style={`background-image: url('${post.data.thumbnail || '/images/blog-default.jpg'}')`}
    >
      <h1 class="px-[1em] text-[2.25rem] font-bold leading-[1.4] sm:text-[1.25rem]">{post.data.title}</h1>
      <div class="px-[1.375rem] text-[0.75rem]">
        {post.data.category && (
          <a href={`/category/${post.data.category.toLowerCase()}/`} class="inline-block px-[1em] text-[#ccc] underline">{post.data.category}</a>
        )}
        <time class="inline-block pt-[1em] text-[#ccc]" datetime={post.data.date.toISOString()}>
          公開日：{formattedDate}
        </time>
        {formattedUpdatedDate && (
          <time class="inline-block pt-[0.5em] pl-[1em] text-[#ccc]" datetime={post.data.updatedDate!.toISOString()}>
            更新日：{formattedUpdatedDate}
          </time>
        )}
      </div>
    </div>

    <!-- 記事本文 -->
    <div class="single__content max-w-[58.75rem] px-5 pt-[2.0625rem] pb-[2.0625rem] mx-auto text-[#333] text-[1rem] leading-[1.8] sm:max-w-[23.4375rem] sm:px-4 sm:pt-[1.375rem]">
      <TableOfContents headings={headings} />
      <div class="prose-content">
        <Content />
      </div>

      <!-- SNS共有ボタン -->
      <ul class="flex flex-wrap items-center pt-[6.875rem] list-none m-0 p-0 gap-2">
        <span class="w-full pl-[1em] text-[0.875rem] text-[#555]">記事をシェアする</span>
        <li class="pt-[1em] pl-[1em]">
          <a
            href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(pageUrl)}&text=${encodeURIComponent(pageTitle)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-4 py-2 rounded text-[0.875rem] font-medium no-underline text-white bg-[#1a1a1a] transition-opacity duration-200 hover:opacity-85"
          >X（Twitter）</a>
        </li>
        <li class="pt-[1em] pl-[1em]">
          <a
            href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-4 py-2 rounded text-[0.875rem] font-medium no-underline text-white bg-[#1877f2] transition-opacity duration-200 hover:opacity-85"
          >Facebook</a>
        </li>
        <li class="pt-[1em] pl-[1em]">
          <a
            href={`https://line.me/R/msg/text/?${encodeURIComponent(pageTitle)}%0A${encodeURIComponent(pageUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-4 py-2 rounded text-[0.875rem] font-medium no-underline text-white bg-[#06c755] transition-opacity duration-200 hover:opacity-85"
          >LINE</a>
        </li>
        <li class="pt-[1em] pl-[1em]">
          <a
            href={`https://getpocket.com/edit?url=${encodeURIComponent(pageUrl)}&title=${encodeURIComponent(pageTitle)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-4 py-2 rounded text-[0.875rem] font-medium no-underline text-white bg-[#ef4056] transition-opacity duration-200 hover:opacity-85"
          >Pocket</a>
        </li>
        <li class="pt-[1em] pl-[1em]">
          <a
            href={`https://b.hatena.ne.jp/add?mode=confirm&url=${encodeURIComponent(pageUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-4 py-2 rounded text-[0.875rem] font-medium no-underline text-white bg-[#00a4de] transition-opacity duration-200 hover:opacity-85"
          >はてブ</a>
        </li>
      </ul>
    </div>

    <!-- パンくずリスト -->
    <div class="page-main">
      <nav class="breadcrumb max-w-[56.25rem] mx-auto" aria-label="パンくずリスト">
        <a href="/">ホーム</a>
        <span class="breadcrumb__sep">></span>
        <a href="/blog/">ブログ</a>
        <span class="breadcrumb__sep">></span>
        <span>{post.data.title}</span>
      </nav>
    </div>

  </main>

</Layout>
