---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="ブログ" description="WEB工房 Swing代表者 船坂 国之の技術ブログです。WEB制作・WEB開発・フリーランスに関することを発信します。基本的に、自分が困った事を解決したり、勉強したことを記録したりしていきます。同じようなことで困った人の役に立てたら幸いです。">

  <main class="page-main">

    <!-- ページタイトル -->
    <h2 class="flex flex-col items-center section-pad section-title mb-0 sm:py-[2.0625rem]">
      Blog
      <span class="pt-4 text-[1.25rem] font-bold">ブログ</span>
    </h2>

    <!-- 記事グリッド（2列） -->
    <section class="blog-grid">
      {posts.map((post) => {
        const formattedDate = post.data.date.toLocaleDateString('ja-JP', {
          year: 'numeric',
          month: '2-digit',
          day: '2-digit',
        });
        return (
          <article class="w-full">
            <a href={`/blog/${post.slug}/`} class="card-hover relative block p-5 no-underline text-inherit">
              <!-- 画像コンテナ（16:9比率） -->
              <div class="thumb-zoom blog-article__img relative mx-auto overflow-hidden rounded-[5px] shadow-[0_3px_10px_rgba(0,0,0,0.2)]">
                <img
                  src={post.data.thumbnail || '/images/blog-default.jpg'}
                  alt={post.data.title}
                  loading="lazy"
                  class="blog-article__thumb block object-cover w-full h-full transition-transform duration-300"
                />
              </div>
              <!-- タイトル -->
              <h3 class="relative blog-article__title mx-auto py-[0.625rem] text-[1.25rem] font-bold text-[#333] z-[1]">{post.data.title}</h3>
              <!-- メタ情報 -->
              <div class="relative flex items-center justify-between blog-article__meta mx-auto text-[0.8125rem] z-[1]">
                <time class="text-[#888]" datetime={post.data.date.toISOString()}>
                  {formattedDate}
                </time>
                {post.data.category && (
                  <p>
                    <span class="text-[0.75rem] text-base bg-green px-[0.8rem] py-[0.2rem] rounded">{post.data.category}</span>
                  </p>
                )}
              </div>
              <!-- 抜粋 -->
              {post.data.excerpt && (
                <p class="relative blog-article__excerpt mx-auto py-4 text-[0.875rem] text-[#555] z-[1]">{post.data.excerpt}</p>
              )}
            </a>
          </article>
        );
      })}
    </section>

    <!-- パンくずリスト -->
    <nav class="breadcrumb max-w-[56.25rem] mx-auto" aria-label="パンくずリスト">
      <a href="/">ホーム</a>
      <span class="breadcrumb__sep">></span>
      <span>ブログ</span>
    </nav>

  </main>

</Layout>

<style>
  /* グリッドレイアウト（カスタム値が必要なため style タグで管理） */
  .blog-grid {
    display: grid;
    grid-template-columns: 31.25rem 31.25rem;
    justify-content: center;
  }

  .blog-article__img {
    width: 28.125rem;
    height: 15.820313rem;
    max-width: 28.125rem;
  }

  .blog-article__title,
  .blog-article__meta,
  .blog-article__excerpt {
    max-width: 28.125rem;
  }

  @media screen and (max-width: 1024px) {
    .blog-grid {
      grid-template-columns: 21.875rem 21.875rem;
    }

    .blog-article__img {
      width: 18.75rem;
      height: 10.546875rem;
      max-width: 18.75rem;
    }

    .blog-article__title,
    .blog-article__meta,
    .blog-article__excerpt {
      max-width: 18.75rem;
    }
  }

  @media screen and (max-width: 767px) {
    .blog-grid {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
  }
</style>
