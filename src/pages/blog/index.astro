---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="ブログ" description="WEB制作 Swing のブログです。WEB制作に関する情報や日記を発信しています。">

  <main class="page__main page__blog">

    <!-- ページタイトル -->
    <h2 class="page__blog__title">
      Blog
      <span>ブログ</span>
    </h2>

    <!-- 記事グリッド（2列） -->
    <section class="blog-grid">
      {posts.map((post) => {
        const formattedDate = post.data.date.toLocaleDateString('ja-JP', {
          year: 'numeric',
          month: '2-digit',
          day: '2-digit',
        });
        return (
          <article class="blog-article">
            <a href={`/blog/${post.slug}/`} class="blog-article__link card-hover">
              <div class="blog-article__img thumb-zoom">
                <img
                  src={post.data.thumbnail || '/images/blog-default.jpg'}
                  alt={post.data.title}
                  loading="lazy"
                  class="blog-article__thumb"
                />
              </div>
              <h3 class="blog-article__title">{post.data.title}</h3>
              <div class="blog-article__meta">
                <time class="blog-article__time" datetime={post.data.date.toISOString()}>
                  {formattedDate}
                </time>
                {post.data.category && (
                  <p class="blog-article__cat">
                    <span>{post.data.category}</span>
                  </p>
                )}
              </div>
              {post.data.excerpt && (
                <p class="blog-article__excerpt">{post.data.excerpt}</p>
              )}
            </a>
          </article>
        );
      })}
    </section>

    <!-- パンくずリスト -->
    <nav class="breadcrumb blog-breadcrumb" aria-label="パンくずリスト">
      <a href="/">Home</a>
      <span class="breadcrumb__sep">></span>
      <span>Blog</span>
    </nav>

  </main>

</Layout>

<style>
  .page__blog {
    background-color: #f4f3ec;
  }

  /* ページタイトル */
  .page__blog__title {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3.4375rem 0; /* 55px */
    font-size: 2.25rem; /* 36px */
    font-weight: bold;
    color: #333;
    text-align: center;
  }

  .page__blog__title span {
    padding-top: 1em;
    font-size: 1.25rem; /* 20px */
  }

  /* グリッドレイアウト（2列・各500px） */
  .blog-grid {
    display: grid;
    grid-template-columns: 31.25rem 31.25rem; /* 500px each */
    justify-content: center;
  }

  .blog-article {
    width: 100%;
  }

  /* 記事カード */
  .blog-article__link {
    position: relative;
    display: block;
    padding: 1.25rem; /* 20px */
    text-decoration: none;
    color: inherit;
  }

  /* 画像コンテナ（16:9比率・450px幅） */
  .blog-article__img {
    position: relative;
    width: 28.125rem; /* 450px */
    height: 15.820313rem; /* 253.125px = 450 * 9/16 */
    margin: auto;
    overflow: hidden;
    border-radius: 5px;
    box-shadow: 0 3px 10px rgba(0, 0, 0, 0.2);
  }

  .blog-article__thumb {
    display: block;
    object-fit: cover;
    width: 100%;
    height: 100%;
    transition: transform 0.3s;
  }

  .blog-article__link:hover .blog-article__thumb {
    transform: scale(1.1);
  }

  /* タイトル */
  .blog-article__title {
    position: relative;
    max-width: 28.125rem; /* 450px */
    margin: auto;
    padding: 0.625rem 0; /* 10px */
    font-size: 1.25rem; /* 20px */
    font-weight: bold;
    color: #333;
    z-index: 1;
  }

  /* メタ情報 */
  .blog-article__meta {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 28.125rem; /* 450px */
    margin: auto;
    font-size: 0.8125rem; /* 13px */
    z-index: 1;
  }

  .blog-article__time {
    color: #888;
  }

  .blog-article__cat span {
    font-size: 0.75rem; /* 12px */
    color: #f4f3ec;
    background-color: #16a34a;
    padding: 0.2rem 0.8rem;
    border-radius: 4px;
  }

  /* 抜粋 */
  .blog-article__excerpt {
    position: relative;
    max-width: 28.125rem; /* 450px */
    margin: auto;
    padding: 1em 0;
    font-size: 0.875rem; /* 14px */
    color: #555;
    z-index: 1;
  }

  /* パンくずリスト */
  .blog-breadcrumb {
    max-width: 56.25rem; /* 900px */
    margin: auto;
  }

  /* レスポンシブ */
  @media screen and (max-width: 1024px) {
    .blog-grid {
      grid-template-columns: 21.875rem 21.875rem; /* 350px each */
    }

    .blog-article__img {
      width: 18.75rem; /* 300px */
      height: 10.546875rem; /* 168.75px */
    }

    .blog-article__title,
    .blog-article__meta,
    .blog-article__excerpt {
      max-width: 18.75rem; /* 300px */
    }
  }

  @media screen and (max-width: 767px) {
    .page__blog__title {
      padding: 2.0625rem 0; /* 33px */
    }

    .blog-grid {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
  }
</style>
