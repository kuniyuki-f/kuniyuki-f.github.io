---
import Layout from '../layouts/Layout.astro';
import WorkCard from '../components/WorkCard.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allWorks = await getCollection('works');
const works = allWorks.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)).slice(0, 3);

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 3);
---

<Layout title="トップページ" description="使えば使うほど好きになる素敵なWEBサイトを制作します。 サービス内容【WEBサイト制作】サーバーの設定からWEBサイトの公開までワンストップで対応いたします。ブログやイラストを投稿できるオウンドメディア、SEOに強いホームページなど、ご要望に応じて様々なサイトを制作いたします。">

  <!-- キャッチコピーセクション（元テーマ準拠：テキストのみ、背景rgba） -->
  <p class="py-[3.4375rem] my-[13.75rem] mx-auto bg-[rgba(244,243,236,0.8)] text-center text-[#333] text-[1.5rem] sm:text-[1.125rem]">
    <strong>使えば使うほど好きになる 素敵なWEBサイトを制作します</strong>
  </p>

  <!-- Serviceセクション -->
  <section class="section-pad page-main text-center sm:py-[2.0625rem]">
    <h2 class="section-title mb-0">Service</h2>
    <p class="max-w-[80rem] px-[1.375rem] py-[1.375rem] mx-auto text-[#333]">
      サーバーの設定からWEBサイトの公開までワンストップで対応いたします。納品後のサポートも承ります。
    </p>
    <div class="grid grid-cols-3 justify-center text-center gap-5 px-5 sm:grid-cols-[6.25rem_6.25rem_6.25rem]"
         style="grid-template-columns: 12.5rem 12.5rem 12.5rem;">
      <div class="px-[0.625rem] py-5">
        <span class="material-icons-outlined block text-[6.25rem] text-[#333] mb-[0.625rem] sm:text-[3.75rem]">web</span>
        <h3 class="text-[1.125rem] font-bold text-brown mb-[0.625rem]">WEBサイト制作</h3>
        <p class="text-[0.875rem] text-[#555] leading-[1.7]">コーポレートサイト・ポートフォリオサイト・ブログ等のオウンドメディアを制作します。SEO対策済み。</p>
      </div>
      <div class="px-[0.625rem] py-5">
        <span class="material-icons-outlined block text-[6.25rem] text-[#333] mb-[0.625rem] sm:text-[3.75rem]">code</span>
        <h3 class="text-[1.125rem] font-bold text-brown mb-[0.625rem]">フロントエンド開発</h3>
        <p class="text-[0.875rem] text-[#555] leading-[1.7]">HTML/CSS/JavaScriptを使ったモダンな開発を行います。</p>
      </div>
      <div class="px-[0.625rem] py-5">
        <span class="material-icons-outlined block text-[6.25rem] text-[#333] mb-[0.625rem] sm:text-[3.75rem]">dns</span>
        <h3 class="text-[1.125rem] font-bold text-brown mb-[0.625rem]">WordPress構築</h3>
        <p class="text-[0.875rem] text-[#555] leading-[1.7]">オリジナルテーマの開発・カスタマイズに対応します。</p>
      </div>
    </div>
  </section>

  <!-- Worksセクション -->
  <section class="section-pad page-main mt-[6.875rem] sm:py-[2.0625rem]">
    <h2 class="section-title mb-0">Works</h2>
    <div class="flex justify-evenly mx-auto my-[3.4375rem] text-center flex-wrap gap-5 md:flex-col md:items-center">
      {works.map((work) => (
        <WorkCard
          title={work.data.title}
          thumbnail={work.data.thumbnail}
          link={work.data.link}
          description={work.data.description}
        />
      ))}
    </div>
    <div class="text-center pb-[1.375rem]">
      <a href="/works/" class="btn-more">もっと見る</a>
    </div>
  </section>

  <!-- Blogセクション -->
  <section class="section-pad page-main mt-[6.875rem] sm:py-[2.0625rem]">
    <h2 class="section-title mb-0">Blog</h2>
    <div class="flex justify-evenly mx-auto my-[3.4375rem] text-center flex-wrap gap-5 md:flex-col md:items-center">
      {posts.map((post) => (
        <BlogCard
          title={post.data.title}
          slug={post.slug}
          date={post.data.date}
          category={post.data.category}
          thumbnail={post.data.thumbnail}
          excerpt={post.data.excerpt}
        />
      ))}
    </div>
    <div class="text-center pb-[1.375rem]">
      <a href="/blog/" class="btn-more">記事一覧へ</a>
    </div>
  </section>

</Layout>

<style>
  /* Service グリッドのレスポンシブ（カスタム値のため style タグで管理） */
  @media screen and (max-width: 767px) {
    .service-grid {
      grid-template-columns: 6.25rem 6.25rem 6.25rem;
    }
  }
</style>
