---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="プロフィール" description="WEB制作 Swing（くにゆき）のプロフィールページです。">

  <main class="page__main profile">

    <!-- ページタイトル -->
    <div class="profile__title">
      <h2>Profile</h2>
    </div>

    <!-- プロフィール説明（写真 + 自己紹介） -->
    <div class="profile__description">
      <figure>
        <img src="/images/me.png" alt="くにゆきのプロフィール写真" />
        <figcaption>
          <p>大阪府在住のフリーランスWEBデザイナー・エンジニアです。</p>
          <p>コーポレートサイトやポートフォリオサイトの制作、WordPressテーマの開発・カスタマイズなどを行っています。</p>
          <p>お問い合わせはフォームか <a href="https://twitter.com/swing_web" target="_blank" rel="noopener noreferrer">Twitter DM（@swing_web）</a> からお気軽にどうぞ！</p>
        </figcaption>
      </figure>
    </div>

    <!-- 事業者情報テーブル -->
    <div class="profile__business">
      <table>
        <tbody>
          <tr>
            <td class="blue">屋号</td>
            <td>WEB制作 Swing</td>
          </tr>
          <tr>
            <td class="blue">代表者名</td>
            <td>国之（くにゆき）</td>
          </tr>
          <tr>
            <td class="blue">所在地</td>
            <td>大阪府</td>
          </tr>
          <tr>
            <td class="blue">連絡先</td>
            <td>
              <a href="/contact/">お問い合わせフォーム</a> または
              <a href="https://twitter.com/swing_web" target="_blank" rel="noopener noreferrer">Twitter DM（@swing_web）</a>
            </td>
          </tr>
          <tr>
            <td class="blue">対応業務</td>
            <td>WEBサイト制作 / フロントエンド開発 / WordPress構築・カスタマイズ</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- パンくずリスト -->
    <nav class="breadcrumb" aria-label="パンくずリスト">
      <a href="/">Home</a>
      <span class="breadcrumb__sep">></span>
      <span>Profile</span>
    </nav>

  </main>

</Layout>

<style>
  .profile {
    background-color: #f4f3ec;
    color: #333;
  }

  /* ページタイトル */
  .profile__title {
    padding-top: 3.4375rem; /* 55px */
    text-align: center;
  }

  .profile__title h2 {
    font-size: 2.25rem; /* 36px */
    font-weight: bold;
  }

  /* 説明部分（写真 + 自己紹介） */
  .profile__description {
    display: flex;
    justify-content: center;
    max-width: 37.5rem; /* 600px */
    margin: 3.4375rem auto; /* 55px */
  }

  .profile__description figure {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .profile__description img {
    width: 10rem; /* 160px */
    height: 10rem; /* 160px */
    object-fit: cover;
    border-radius: 50%;
    border: 4px solid #59483b;
  }

  .profile__description figcaption {
    width: 100%;
    padding: 1em;
    margin: 0 auto;
    font-size: 0.9375rem; /* 15px */
    line-height: 1.8;
    color: #555;
  }

  .profile__description figcaption a {
    color: #16a34a;
    text-decoration: underline;
  }

  .profile__description figcaption p {
    margin-bottom: 0.8em;
  }

  /* 事業者情報テーブル */
  .profile__business {
    max-width: 37.5rem; /* 600px */
    padding: 1em;
    margin: auto;
  }

  .profile__business table {
    width: 100%;
    border-collapse: collapse;
  }

  .profile__business td {
    padding: 0.75rem 1rem; /* 12px 16px */
    font-size: 0.9375rem; /* 15px */
    border-bottom: 1px solid rgba(89, 72, 59, 0.15);
    vertical-align: top;
    line-height: 1.6;
  }

  /* テーブルヘッダーセル（ブラウン背景） */
  .profile__business .blue {
    color: #f4f3ec;
    background-color: #59483b;
    font-weight: bold;
    white-space: nowrap;
    width: 7.5rem; /* 120px */
  }

  .profile__business td a {
    color: #16a34a;
    text-decoration: underline;
  }

  /* パンくずリスト */
  .breadcrumb {
    max-width: 37.5rem; /* 600px */
    margin: auto;
  }

  /* レスポンシブ */
  @media screen and (max-width: 767px) {
    .profile__title {
      padding-top: 2.0625rem; /* 33px */
    }

    .profile__description {
      margin: 2.0625rem auto; /* 33px */
    }

    .profile__description img {
      width: 7.5rem; /* 120px */
      height: 7.5rem; /* 120px */
    }

    /* テーブル行を縦並びに */
    .profile__business tr {
      display: flex;
      flex-direction: column;
    }

    .profile__business td {
      padding: 0.5em;
    }

    .profile__business .blue {
      width: 100%;
      margin-top: 1.375rem; /* 22px */
    }
  }
</style>
