---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allWorks = await getCollection('works');
const works = allWorks.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Layout title="制作実績" description="WEB工房 Swingの制作実績です。非公開の案件でも、これまで10件以上のWEB制作・システム保守案件に携わってまいりました。">

  <main class="page-main">

    <!-- ページタイトル -->
    <div class="page-main section-pad text-center">
      <h2 class="section-title">Works</h2>
      <p class="max-w-[37.5rem] mx-auto px-4 pt-[1.375rem] text-[0.9375rem] leading-[1.8] text-[#555]">
        制作実績を公開しています。非公開の案件でも、これまで10件以上のWEB制作・システム保守案件に携わってまいりました。
      </p>
      <p class="max-w-[37.5rem] mx-auto px-4 pt-[0.5rem] text-[0.8125rem] text-[#888]">
        ※ 下記コンテンツをクリックまたはタップすると別タブでページが開きます。
      </p>
    </div>

    <!-- 実績カード一覧（縦1列） -->
    <div>
      {works.map((work) => (
        <article class="section-pad page-main border-b border-brown/10 sm:py-[2.0625rem]">
          <div>
            <a
              href={work.data.link}
              target="_blank"
              rel="noopener noreferrer"
              class="card-hover relative flex flex-col items-center max-w-[40rem] px-5 py-[3.4375rem] mx-auto no-underline sm:max-w-[20rem] sm:py-[2.0625rem]"
            >
              <!-- 画像コンテナ（16:9比率・600px幅） -->
              <div class="thumb-zoom relative w-[37.5rem] h-[21.09375rem] overflow-hidden rounded-[5px] shadow-[0_3px_10px_rgba(0,0,0,0.2)] sm:w-[18.75rem] sm:h-[10.546875rem]">
                <img
                  src={work.data.thumbnail}
                  alt={work.data.title}
                  loading="lazy"
                  class="object-cover w-full h-full transition-transform duration-300"
                />
              </div>
              <!-- タイトル -->
              <h3 class="card-title pt-[1.375rem]">{work.data.title}</h3>
              <!-- 説明文 -->
              {work.data.description && (
                <p class="card-desc pt-[1.375rem] text-center">{work.data.description}</p>
              )}
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- 非公開案件注記（導入テキストに統合したため削除） -->

    <!-- パンくずリスト -->
    <nav class="breadcrumb max-w-[56.25rem] mx-auto" aria-label="パンくずリスト">
      <a href="/">ホーム</a>
      <span class="breadcrumb__sep">></span>
      <span>制作実績</span>
    </nav>

  </main>

</Layout>
